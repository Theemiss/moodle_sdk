# Moodle Connection Settings
MOODLE_URL=https://your-moodle-instance.com
MOODLE_TOKEN=your_web_service_token_here
MOODLE_SERVICE_NAME=your_service_name

# Request Settings
MOODLE_REQUEST_TIMEOUT=30
MOODLE_MAX_RETRIES=3
MOODLE_RETRY_BACKOFF_FACTOR=0.5

# Logging
MOODLE_LOG_LEVEL=INFO
MOODLE_LOG_FORMAT=json

# Bulk Operation Settings
MOODLE_BULK_CHUNK_SIZE=50